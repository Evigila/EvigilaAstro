---
import SiteLayout from '../layouts/SiteLayout.astro';

const friendLinks = [
	{
		name: 'Northlight Notes',
		href: 'https://example.com/northlight',
		description: '示例网址。',
	},
	{
		name: 'Quiet Build',
		href: 'https://example.com/quiet-build',
		description: '示例网址。',
	},
	{
		name: 'Archive Field',
		href: 'https://example.com/archive-field',
		description: '示例网址。',
	},
];
---

<SiteLayout title="友链 | Evigila" description="Evigila 的友链页面。">
	<main class="post-shell">
		<a class="post-back ui-button" href="/">返回首页</a>
		<article class="post-article">
			<header class="post-hero">
				<p class="post-kicker">Friends</p>
				<h1>友链</h1>
				<p class="post-excerpt">
					这里先放一组示例友链占位结构。
				</p>
			</header>
			<div class="post-content">
				<ul>
					{friendLinks.map((link) => (
						<li>
							<strong><a href={link.href}>{link.name}</a></strong>
							<p>{link.description}</p>
						</li>
					))}
				</ul>
			</div>
		</article>
	</main>
</SiteLayout>