---
import { getCollection } from 'astro:content';
import { getSortedTagNamesByCount, sortPostsByUpdatedAt } from '../data/blog';
import Hero from '../components/Hero.astro';
import PostGrid from '../components/PostGrid.astro';
import { siteConfig } from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';
import { ICONS } from '../data/icons';

const posts = sortPostsByUpdatedAt(await getCollection('blog'));
const tags = getSortedTagNamesByCount(posts);
---

<SiteLayout title={siteConfig.title} description={siteConfig.description}>
	<main class="home-shell" id="top">
		<section class="landing-stage" data-stage-shell>
			<div class="landing-stage__sticky">
				<div class="stage-ambient" aria-hidden="true"></div>
			</div>
		</section>

		<Hero />

		<section class="hero-tag-shelf" id="hero-tag-shelf" data-tag-shelf hidden>
			<div class="hero-tag-shelf__inner" aria-label="全部标签筛选" role="radiogroup">
				<button
					class="chip-button ui-button hero-shelf-tag is-active"
					type="button"
					data-tag-filter="all"
					role="radio"
					aria-checked="true"
					tabindex="0"
				>
					无过滤
				</button>
				{tags.map((tag) => (
					<button
						class="chip-button ui-button hero-shelf-tag"
						type="button"
						data-tag-filter={tag}
						role="radio"
						aria-checked="false"
						tabindex="-1"
					>
						{tag}
					</button>
				))}
			</div>
		</section>

		<div class="dock-controls">
			<button
				class="action-button ui-button ui-button--square hero-browse-toggle"
				type="button"
				data-tags-expand-toggle
				aria-pressed="false"
				aria-expanded="false"
				aria-controls="hero-tag-shelf"
				aria-label="标签筛选"
			>
				<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d={ICONS.tags} fill="currentColor"/>
				</svg>
				<span class="sr-only">标签筛选</span>
			</button>

			<div class="dock-search" aria-label="停靠模式搜索占位">
				<label class="hero-search hero-search--dock" for="dock-search-input">
					<span class="sr-only">搜索全站内容</span>
					<input
						class="hero-search__input"
						id="dock-search-input"
						type="search"
						name="dock-q"
						placeholder="搜索全站内容"
						autocomplete="off"
					/>
				</label>
			</div>

			<button class="floating-home ui-button ui-button--square" type="button" data-scroll-top>
				<svg class="floating-home__icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d={ICONS.arrowUp} fill="currentColor"/>
				</svg>
				<span class="sr-only">回到顶端</span>
			</button>
		</div>

		<section class="home-feed" id="posts">
			<div class="feed-toolbar">
				<p data-feed-summary>Archive / {posts.length} Posts</p>
				<button class="action-button ui-button" type="button" data-scroll-top>
					回到顶端
				</button>
			</div>
			<div class="home-feed__grid">
				<PostGrid posts={posts} />
			</div>
			<p class="feed-empty" hidden data-feed-empty>当前标签下没有文章，换一个标签再看。</p>
		</section>
	</main>

	<script>
		import { initHomePage } from '../scripts/home';

		initHomePage();
	</script>
</SiteLayout>
