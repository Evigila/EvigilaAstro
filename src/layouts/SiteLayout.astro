---
import '../styles/global.css';
import Toast from '../components/Toast.astro';

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = 'Evigila 的极简静态博客原型。',
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme="light">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="icon" type="image/jpeg" href="/avatar.jpg" />
		<link rel="apple-touch-icon" href="/avatar.jpg" />
		<title>{title}</title>
		<script is:inline>
			(() => {
				const storedTheme = localStorage.getItem('evigila-theme');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = storedTheme ?? (prefersDark ? 'dark' : 'light');
				document.documentElement.dataset.theme = theme;
				const storedFontSize = localStorage.getItem('evigila-font-size');
				if (storedFontSize && storedFontSize !== 'normal') {
					document.documentElement.dataset.fontSize = storedFontSize;
				}
			})();
		</script>
	</head>
	<body>
		<slot />
		<Toast />
	</body>
</html>