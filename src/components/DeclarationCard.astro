			</svg>
			<span class="decl-card__label">分享本文</span>
			<button class="decl-card__link decl-card__copy-btn" type="button" data-copy={canonicalUrl}>{canonicalUrl}</button>
		</div>

		<div class="decl-card__row">
			<svg class="decl-card__icon" viewBox="0 0 24 24" aria-hidden="true">
				<path d="M12,2A10,10,0,1,0,22,12,10.011,10.011,0,0,0,12,2Zm0,18a8,8,0,1,1,8-8A8.009,8.009,0,0,1,12,20Zm.5-13H11v6l5.25,3.15.75-1.23-4.5-2.67Z" fill="currentColor"/>
			</svg>
