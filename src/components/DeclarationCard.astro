	</svg>

	<div class="decl-card__body">
		<p class="decl-card__kicker">Declaration</p>

		<div class="decl-card__row">
			<svg class="decl-card__icon" viewBox="0 0 24 24" aria-hidden="true">
				<path d="M21,11H6.83l3.58-3.59L9,6l-6,6,6,6,1.41-1.41L6.83,13H21Z" fill="currentColor"/>
			</svg>
