			</svg>
			<span class="decl-card__label">版权协议</span>
			<a
				class="decl-card__link"
				href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.zh-hans"
				target="_blank"
				rel="noopener noreferrer"
			>{license}</a>
		</div>
	</div>
</div>

<style>
	.decl-card {
		--decl-bg: linear-gradient(135deg, #dbeeff 0%, #c8e4fb 100%);
		--decl-border: #9fc8f0;
		--decl-text: #1b3a5c;
		--decl-text-label: #1b3a5c;
		--decl-watermark: rgba(15, 108, 189, 0.1);

		position: relative;
		overflow: hidden;
		padding: clamp(1.4rem, 3vw, 2rem);
		background: var(--decl-bg);
		border: 1px solid var(--decl-border);
		font-family: var(--font-body);
	}

	:root[data-theme='dark'] .decl-card {
		--decl-bg: linear-gradient(135deg, #0d2340 0%, #112d4a 100%);
		--decl-border: #1e4a73;
		--decl-text: #c0d8f0;
		--decl-text-label: #90c4e8;
		--decl-watermark: rgba(76, 194, 255, 0.08);
	}

	.decl-card__watermark {
		position: absolute;
		right: -1.5rem;
		top: 50%;
		transform: translateY(-50%);
		width: clamp(7rem, 18vw, 12rem);
		height: auto;
		fill: var(--decl-watermark);
		pointer-events: none;
		user-select: none;
	}

	.decl-card__body {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 0.75rem;
		max-width: calc(100% - 8rem);
	}

	.decl-card__kicker {
		margin: 0 0 0.25rem;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent-0);
	}

	.decl-card__row {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		font-size: 0.88rem;
		color: var(--decl-text);
		line-height: 1.4;
	}

	.decl-card__icon {
		flex: none;
		width: 1rem;
		height: 1rem;
		color: var(--accent-0);
		opacity: 0.8;
	}

	.decl-card__label {
		flex: none;
		font-weight: 600;
		min-width: 5rem;
		color: var(--decl-text-label);
	}

	.decl-card__link {
		color: var(--accent-0);
		text-decoration: underline;
		text-decoration-thickness: 0.08em;
		text-underline-offset: 0.15em;
		word-break: break-all;
	}

	.decl-card__copy-btn {
		background: none;
		border: none;
		padding: 0;
		font: inherit;
		cursor: pointer;
		text-align: left;
	}

	.decl-card__copy-btn:hover {
		opacity: 0.75;
	}
</style>

<script>
	const _showToast = (msg: string) =>
		(window as unknown as { showToast?: (m: string) => void }).showToast?.(msg);

	document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const text = btn.dataset.copy ?? '';
			try {
				await navigator.clipboard.writeText(text);
			} catch {
				const textarea = document.createElement('textarea');
				textarea.value = text;
				textarea.style.cssText = 'position:fixed;opacity:0;pointer-events:none;';
				document.body.appendChild(textarea);
				textarea.select();
				document.execCommand('copy');
				document.body.removeChild(textarea);
			}
			_showToast('感谢分享，已复制到剪贴板喵~');
		});
	});
</script>
