---
interface Props {
	publishDate: Date;
	license: string;
}

const { publishDate, license } = Astro.props;

const SITE_URL = 'https://blog.evigila.net';
const postPath = Astro.url.pathname;
const canonicalUrl = SITE_URL + postPath;

const publishedLabel = publishDate.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

