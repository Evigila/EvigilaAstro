---
import { siteConfig } from '../data/site';

interface Props {}

Astro.props;
---

<section class="home-hero" data-home-hero aria-label="首页 Hero 区域">
	<div class="home-hero__panel">
		<div class="hero-avatar">
			<img
				src={siteConfig.author.avatar}
				alt={`${siteConfig.author.name} avatar`}
				width="120"
				height="120"
				loading="eager"
			/>
		</div>
		<div class="hero-copy">
			<p class="hero-kicker">Static Journal</p>
			<h1>{siteConfig.name}</h1>
			<p class="hero-bio">{siteConfig.author.bio}</p>
			<p class="hero-signature">{siteConfig.author.signature}</p>
		</div>
		<div class="hero-actions">
			<div class="hero-row hero-row--utility">
				<button
					class="action-button ui-button ui-button--square hero-icon-button theme-toggle"
					type="button"
					data-theme-toggle
					aria-pressed="false"
					aria-label="切换主题"
				>
					<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path d="m13 22v1c0 .553-.448 1-1 1s-1-.447-1-1v-1c0-.553.448-1 1-1s1 .447 1 1zm-1-19c.552 0 1-.448 1-1v-1c0-.552-.448-1-1-1s-1 .448-1 1v1c0 .552.448 1 1 1zm11 8h-1c-.553 0-1 .448-1 1s.447 1 1 1h1c.553 0 1-.448 1-1s-.447-1-1-1zm-21 0h-1c-.552 0-1 .448-1 1s.448 1 1 1h1c.552 0 1-.448 1-1s-.448-1-1-1zm2.222 7.364-.707.707c-.391.391-.391 1.023 0 1.414s1.023.391 1.414 0l.707-.707c.391-.391.391-1.023 0-1.414s-1.023-.391-1.414 0zm14.849-14.849-.707.707c-.391.391-.391 1.023 0 1.414s1.023.391 1.414 0l.707-.707c.391-.391.391-1.023 0-1.414s-1.023-.391-1.414 0zm.707 14.85c-.391-.391-1.023-.391-1.414 0s-.391 1.023 0 1.414l.707.707c.391.391 1.023.391 1.414 0s.391-1.023 0-1.414zm-15.556-12.729c.391.391 1.023.391 1.414 0s.391-1.023 0-1.414l-.707-.707c-.391-.391-1.023-.391-1.414 0s-.391 1.023 0 1.414zm14.778 6.364c0 3.859-3.141 7-7 7s-7-3.141-7-7 3.14-7 7-7 7 3.14 7 7zm-2 0c0-2.757-2.243-5-5-5v10c2.757 0 5-2.243 5-5z" fill="currentColor"></path>
					</svg>
					<span class="sr-only">切换主题，当前</span>
					<strong class="sr-only" data-theme-label>浅色</strong>
				</button>
				<div class="hero-socials" aria-label="站外跳转">
					{siteConfig.socials.map((item) => (
						<a class="chip-link ui-button ui-button--square hero-icon-button" href={item.href} aria-label={item.label}>
							{item.icon === 'github' ? (
								<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
									<path d="M12 2.5a9.5 9.5 0 0 0-3 18.514c.475.087.65-.206.65-.456 0-.225-.012-.969-.012-1.756-2.388.437-3.006-.581-3.194-1.113-.1-.256-.531-1.112-.906-1.337-.306-.163-.744-.569-.012-.581.693-.013 1.188.637 1.35.9.794 1.338 2.063.963 2.569.731.081-.575.312-.962.568-1.181-2.113-.238-4.319-1.056-4.319-4.694 0-1.037.369-1.894.975-2.563-.1-.237-.425-1.212.094-2.524 0 0 .794-.256 2.606.975a9.031 9.031 0 0 1 4.75 0c1.812-1.243 2.606-.975 2.606-.975.519 1.312.194 2.287.094 2.524.606.669.975 1.519.975 2.563 0 3.65-2.219 4.456-4.331 4.694.319.275.6.8.6 1.625 0 1.175-.012 2.125-.012 2.425 0 .25.175.55.65.456A9.503 9.503 0 0 0 12 2.5Z" fill="currentColor"></path>
								</svg>
							) : (
								<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
									<path d="M3.75 5.25h16.5A2.25 2.25 0 0 1 22.5 7.5v9a2.25 2.25 0 0 1-2.25 2.25H3.75A2.25 2.25 0 0 1 1.5 16.5v-9a2.25 2.25 0 0 1 2.25-2.25Zm0 1.5a.75.75 0 0 0-.75.75v.345l9 5.25 9-5.25V7.5a.75.75 0 0 0-.75-.75H3.75Zm17.25 2.827-8.622 5.03a.75.75 0 0 1-.756 0L3 9.577V16.5c0 .414.336.75.75.75h16.5a.75.75 0 0 0 .75-.75V9.577Z" fill="currentColor"></path>
								</svg>
							)}
							<span class="sr-only">{item.label}</span>
						</a>
					))}
				</div>
			</div>
			<nav class="hero-row hero-row--nav" aria-label="站点导航">
				{siteConfig.navigation.map((item) => (
					<a class="chip-link ui-button hero-nav-link" href={item.href}>{item.label}</a>
				))}
			</nav>
			<div class="hero-row hero-row--search" aria-label="站内搜索占位">
				<label class="hero-search" for="hero-search-input">
					<span class="sr-only">搜索全站内容</span>
					<input
						class="hero-search__input"
						id="hero-search-input"
						type="search"
						name="q"
						placeholder="搜索全站内容"
						autocomplete="off"
					/>
				</label>
				<button
					class="chip-button ui-button hero-browse-toggle"
					type="button"
					data-tags-expand-toggle
					aria-pressed="true"
					aria-expanded="true"
					aria-controls="hero-tag-shelf"
				>
					标签
				</button>
			</div>
		</div>
	</div>
</section>