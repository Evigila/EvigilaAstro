---
import { siteConfig } from '../data/site';
import { ICONS } from '../data/icons';

interface Props {}

Astro.props;
---

<section class="home-hero" data-home-hero aria-label="首页 Hero 区域">
	<div class="home-hero__panel">
		<div class="hero-avatar">
			<img
				src={siteConfig.author.avatar}
				alt={`${siteConfig.author.name} avatar`}
				width="120"
				height="120"
				loading="eager"
			/>
		</div>
		<div class="hero-copy">
			<p class="hero-kicker">Static Journal</p>
			<h1>{siteConfig.name}</h1>
			<p class="hero-bio">{siteConfig.author.bio}</p>
			<p class="hero-signature">{siteConfig.author.signature}</p>
		</div>
		<div class="hero-actions">
			<div class="hero-control-box">

				<!-- Row 1 · 6 icon buttons -->
				<div class="hero-ctrl-row hero-ctrl-icons" role="group" aria-label="快捷操作">

					<!-- 主题 -->
					<button
						class="action-button ui-button ui-button--square hero-icon-button theme-toggle"
						type="button"
						data-theme-toggle
						aria-pressed="false"
						aria-label="切换主题"
					>
						<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path d={ICONS.theme} fill="currentColor"/>
						</svg>
						<span class="sr-only">切换主题，当前</span>
						<strong class="sr-only" data-theme-label>浅色</strong>
					</button>

					<!-- 字体 -->
					<div class="hero-font-wrap">
						<button
							class="action-button ui-button ui-button--square hero-icon-button"
							type="button"
							data-font-toggle
							aria-expanded="false"
							aria-haspopup="true"
							aria-label="调整字体大小"
						>
							<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d={ICONS.font} fill="currentColor"/>
							</svg>
							<span class="sr-only">字体大小</span>
						</button>
						<div class="hero-font-popup" data-font-popup hidden>
							<p class="hero-font-popup__label">字号</p>
							<div class="hero-font-popup__track">
								<span class="hero-font-popup__min">小</span>
								<input
									class="hero-font-popup__slider"
									type="range"
									min="0"
									max="2"
									step="1"
									value="1"
									data-font-slider
									aria-label="字体大小调节"
								/>
								<span class="hero-font-popup__max">大</span>
							</div>
						</div>
					</div>

					<!-- 分享 -->
					<button
						class="action-button ui-button ui-button--square hero-icon-button"
						type="button"
						data-share
						aria-label="分享当前页面"
					>
						<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path d={ICONS.share} fill="currentColor"/>
						</svg>
						<span class="sr-only">分享</span>
					</button>

					<!-- GitHub -->
					{siteConfig.socials.filter((item) => item.icon === 'github').map((item) => (
						<a class="chip-link ui-button ui-button--square hero-icon-button" href={item.href} aria-label={item.label}>
							<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d={ICONS.github} fill="currentColor"/>
							</svg>
							<span class="sr-only">{item.label}</span>
						</a>
					))}

					<!-- 邮件 -->
					<a
						class="chip-link ui-button ui-button--square hero-icon-button"
						href="mailto:evigila.shangyi@gmail.com"
						aria-label="发送邮件"
					>
						<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d={ICONS.mail} fill="currentColor"/>
						</svg>
						<span class="sr-only">发送邮件</span>
					</a>

					<!-- 标签 -->
					<button
						class="action-button ui-button ui-button--square hero-icon-button"
						type="button"
						data-tags-expand-toggle
						aria-pressed="false"
						aria-expanded="false"
						aria-controls="hero-tag-shelf"
						aria-label="标签筛选"
					>
						<svg class="hero-icon" viewBox="0 0 24 24" aria-hidden="true">
						<path d={ICONS.tags} fill="currentColor"/>
						</svg>
						<span class="sr-only">标签筛选</span>
					</button>

				</div>

				<!-- Row 2 · 导航 -->
				<nav class="hero-ctrl-row hero-ctrl-nav" aria-label="站点导航">
					{siteConfig.navigation.map((item) => (
						<a class="chip-link ui-button hero-nav-link" href={item.href}>{item.label}</a>
					))}
				</nav>

				<!-- Row 3 · 搜索框 -->
				<div class="hero-ctrl-row hero-ctrl-search" aria-label="站内搜索占位">
					<label class="hero-search" for="hero-search-input">
						<span class="sr-only">搜索全站内容</span>
						<input
							class="hero-search__input"
							id="hero-search-input"
							type="search"
							name="q"
							placeholder="搜索全站内容"
							autocomplete="off"
						/>
					</label>
				</div>

			</div>
		</div>
	</div>
</section>