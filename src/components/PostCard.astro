---
import type { CollectionEntry } from 'astro:content';
import { getPostSlug } from '../data/blog';
import { siteConfig } from '../data/site';

interface Props {
	post: CollectionEntry<'blog'>;
	index: number;
}

const { post, index } = Astro.props;

const stageDigit = Number(siteConfig.stageSeed[index % siteConfig.stageSeed.length] ?? 5);
const cardMinHeight = Math.max(18.5, 24.5 + (stageDigit - 5) * 1.15);
const publishedLabel = post.data.publishDate.toLocaleDateString('zh-CN', {
	month: 'short',
	day: 'numeric',
});
const tagData = post.data.tags.join('|');
const postSlug = getPostSlug(post);
---

<article
	class="post-card"
	data-post-card
	data-tags={tagData}
	style={`--card-min:${cardMinHeight}rem; --card-delay:${index * 70}ms; --card-accent:${stageDigit};`}
>
	<a class="post-card__link" href={`/posts/${postSlug}/`}>
		<div class="post-card__topline">
			<span class="post-card__date">{publishedLabel}</span>
			<span class="post-card__reading">{post.data.readingTime}</span>
		</div>
		<h2>{post.data.title}</h2>
		<p class="post-card__excerpt">{post.data.excerpt}</p>
		<div class="post-card__meta">
			<div class="post-card__tags">
				{post.data.tags.map((tag) => <span>{tag}</span>)}
			</div>
			<span class="post-card__cta">Read Post</span>
		</div>
	</a>
</article>