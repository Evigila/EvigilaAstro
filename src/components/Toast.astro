---
---

<!-- 氛围光：固定在屏幕底部中央 -->
<div class="site-toast-ambient" aria-hidden="true" id="site-toast-ambient"></div>

<!-- Toast 本体 -->
<div class="site-toast" id="site-toast" role="status" aria-live="polite" aria-atomic="true">
	<!-- 旋转浮光边框 -->
	<div class="site-toast__ring-wrap" aria-hidden="true">
		<div class="site-toast__ring-spin"></div>
	</div>
	<!-- 内容层 -->
	<div class="site-toast__body">
		<span id="site-toast-text"></span>
	</div>
</div>

<style>
	/* ── 氛围光 ─────────────────────────────────────────────── */
	.site-toast-ambient {
		position: fixed;
		bottom: 0;
		left: 50%;
		transform: translateX(-50%);
		width: min(72vw, 920px);
		height: 48vh;
		pointer-events: none;
		z-index: 198;
		opacity: 0;
		background: radial-gradient(
			ellipse 75% 80% at 50% 100%,
			rgba(13, 133, 67, 0.3) 0%,
			rgba(10, 181, 224, 0.18) 38%,
			transparent 72%
		);
		filter: blur(22px);
		transition: opacity 1500ms ease;
	}

	.site-toast-ambient.is-visible {
		opacity: 1;
		animation: toast-ambient-breathe 3.2s ease-in-out infinite;
	}

	@keyframes toast-ambient-breathe {
		0%   { opacity: 1;    filter: blur(22px); }
		22%  { opacity: 0.62; filter: blur(26px); }
		45%  { opacity: 0.85; filter: blur(20px); }
		70%  { opacity: 0.54; filter: blur(28px); }
		88%  { opacity: 0.9;  filter: blur(21px); }
		100% { opacity: 1;    filter: blur(22px); }
	}

	/* ── Toast 容器（仅做定位，无背景） ───────────────────── */
	.site-toast {
		position: fixed;
		left: 50%;
		bottom: 2.5rem;
		transform: translateX(-50%) translateY(0.9rem);
		z-index: 200;
		opacity: 0;
		pointer-events: none;
		transition: opacity 260ms ease, transform 260ms ease;
	}

	.site-toast.is-visible {
		opacity: 1;
		transform: translateX(-50%) translateY(0);
	}

	/* ── 旋转浮光边框 ────────────────────────────────────────── */
	.site-toast__ring-wrap {
		position: absolute;
		inset: -1px;
		overflow: hidden;
		/* 默认隐藏，出现时淡入 */
		opacity: 0;
		transition: opacity 260ms ease;
	}

	.site-toast.is-visible .site-toast__ring-wrap {
		opacity: 1;
	}

	/* 旋转的圆锥渐变正方形 */
	.site-toast__ring-spin {
		position: absolute;
		/* 足够大，旋转时覆盖整个边框 */
		width: 220%;
		aspect-ratio: 1;
		top: 50%;
		left: 50%;
		translate: -50% -50%;
		background: conic-gradient(
			from 0deg,
			transparent 0%,
			#00d4ff 15%,
			#00ffcc 32%,
			#3399ff 50%,
			transparent 65%,
			transparent 100%
		);
		animation: toast-ring-rotate 2.2s linear infinite;
	}

	@keyframes toast-ring-rotate {
		to { rotate: 360deg; }
	}

	/* ── 内容层（拥有背景和毛玻璃） ───────────────────────── */
	.site-toast__body {
		position: relative;
		z-index: 1;
		padding: 0.65rem 1.4rem;
		background: var(--surface-0);
		backdrop-filter: blur(24px);
		-webkit-backdrop-filter: blur(24px);
		box-shadow: var(--shadow-0);
		font-family: var(--font-ui);
		font-size: 0.9rem;
		color: var(--text-0);
		white-space: nowrap;
		/* 内边距补偿边框的 2px 缩进 */
		margin: 1px;
	}
</style>

<script>
	const _toastEl = document.getElementById('site-toast') as HTMLElement;
	const _ambientEl = document.getElementById('site-toast-ambient') as HTMLElement;
	const _toastTextEl = document.getElementById('site-toast-text') as HTMLElement;
	let _toastTimer: ReturnType<typeof setTimeout> | null = null;

	function showToast(message: string, duration = 3000): void {
		_toastTextEl.textContent = message;
		_toastEl.classList.add('is-visible');
		_ambientEl.classList.add('is-visible');

		if (_toastTimer !== null) clearTimeout(_toastTimer);
		_toastTimer = setTimeout(() => {
			_toastEl.classList.remove('is-visible');
			_ambientEl.classList.remove('is-visible');
			_toastTimer = null;
		}, duration);
	}

	// 挂载到 window，供其他脚本调用
	(window as unknown as { showToast: typeof showToast }).showToast = showToast;
</script>
